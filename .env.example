# ═══════════════════════════════════════════════════════════
# BlueSME Environment Configuration
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ── System Mode ──────────────────────────────────────────
# Set to "0" for live mode (real LLM + blockchain)
# Set to "1" for test mode (deterministic mocked outputs)
BLUESME_TEST_MODE=1

# ── LLM Provider ─────────────────────────────────────────
# Supported: gemini/gemini-1.5-pro, openai/gpt-4o, etc.
BLUESME_MODEL=gemini/gemini-1.5-pro
GOOGLE_API_KEY=your-google-api-key-here
OPENAI_API_KEY=your-openai-api-key-here   # optional fallback

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bluesme
POSTGRES_USER=bluesme
POSTGRES_PASSWORD=bluesme_secret

# Alternative: single DSN (overrides the above if set)
# DATABASE_URL=postgresql+psycopg2://bluesme:bluesme_secret@localhost:5432/bluesme

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Celery Workers ────────────────────────────────────────
CELERY_CONCURRENCY=4

# ── Queue Bridge (FastAPI) ────────────────────────────────
QUEUE_BRIDGE_URL=http://localhost:8001
# Set to "1" to route API calls through Celery queue
QUEUE_MODE=0

# ── Authentication ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_long_random_secret_here
JWT_EXPIRY_SECONDS=86400

# ── Blockchain ────────────────────────────────────────────
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
CHAIN_ID=84532   # Base Sepolia
RPC_URL=https://sepolia.base.org
PRIVATE_KEY=your-wallet-private-key-here   # DO NOT commit!

# ── Application URLs ──────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Python Interpreter ────────────────────────────────────
# Absolute path to python in your venv (override auto-detection)
# BLUESME_PYTHON=/home/mark/Desktop/BLUE-SME-AI-main/venv/bin/python

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=pretty     # "pretty" for dev, "json" for production

# ── SQLAlchemy ────────────────────────────────────────────
SQLALCHEMY_ECHO=0     # Set to 1 to log all SQL queries
BLUESME_USE_POOL=0    # Set to 1 for QueuePool (API server), 0 for workers

# ── Debug ─────────────────────────────────────────────────
DEBUG=0               # Set to 1 to enable FastAPI /docs endpoint
